  "recipeIngredient": [
    {
      "name": "2 1/2 cups all-purpose flour"
    },
    {
      "name": "1/2 cup unsweetened cocoa powder"
    },
    {
      "name": "1 teaspoon salt"
    },
    {
      "name": "1 teaspoon baking soda"
    },
    {
      "name": "1/2 teaspoon baking powder"
    },
    {
      "name": "1 teaspoon ground cinnamon"
    },
    {
      "name": "1 cup coconut oil (melted)"
    },
    {
      "name": "2/3 cup granulated sugar"
    },
    {
      "name": "2/3 cup light brown sugar"
    },
    {
      "name": "1/2 cup sour cream"
    },
    {
      "name": "3 large eggs"
    },
    {
      "name": "2 teaspoons pure vanilla extract"
    },
    {
      "name": "2 1/2 cups grated zucchini"
    },
    {
      "name": "1 cup semi-sweet chocolate chips"
    },
    {
      "name": "3/4 cup shredded sweetened coconut"
    }
  ],
  "recipeInstructions": [
    {
      "text": "Preheat oven to 350°F. Spray two 8x4-inch loaf pans with baking spray and/or line with parchment paper.",
      "url": "https://www.mybakingaddiction.com/chocolate-coconut-zucchini-bread/#wprm-recipe-30729-step-0-0"
    },
    {
      "text": "In a medium bowl, whisk together the flour, cocoa, salt, baking soda, baking powder and cinnamon.",
      "url": "https://www.mybakingaddiction.com/chocolate-coconut-zucchini-bread/#wprm-recipe-30729-step-0-1"
    },
    {
      "text": "In a large bowl with an electric mixer, mix the coconut oil and sugars until combined. Mix in the sour cream. Add in the eggs and vanilla and mix until thoroughly incorporated.",
      "url": "https://www.mybakingaddiction.com/chocolate-coconut-zucchini-bread/#wprm-recipe-30729-step-0-2"
    },
    {
      "text": "Slowly add dry ingredients to wet ingredients and mix until just combined.",
      "url": "https://www.mybakingaddiction.com/chocolate-coconut-zucchini-bread/#wprm-recipe-30729-step-0-3"
    },
    {
      "text": "Add in the zucchini and mix for about 1 minute, or until the batter is moistened and the zucchini is evenly incorporated into the batter. Stir in the chocolate chips and shredded coconut.",
      "url": "https://www.mybakingaddiction.com/chocolate-coconut-zucchini-bread/#wprm-recipe-30729-step-0-4"
    },
    {
      "text": "Spread the batter into the prepared pans and bake in preheated oven for 55-60 minutes, or until a toothpick inserted into the center comes out clean.",
      "url": "https://www.mybakingaddiction.com/chocolate-coconut-zucchini-bread/#wprm-recipe-30729-step-0-5"
    },
    {
      "text": "Cool bread in pan for 30 minutes. Remove bread to a wire rack to cool completely.",
      "url": "https://www.mybakingaddiction.com/chocolate-coconut-zucchini-bread/#wprm-recipe-30729-step-0-6"
    }
  ],
