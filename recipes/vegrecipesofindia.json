  "recipeIngredient": [
    {
      "name": "1 bunch mustard greens ((sarson))"
    },
    {
      "name": "½ bunch bathua leaves ((chenopodium/goosefoot/melde))"
    },
    {
      "name": "½ bunch spinach leaves ((palak))"
    },
    {
      "name": "1 cup chopped radish leaves (- use tender leaves, (mooli ke patte))"
    },
    {
      "name": "3 to 4 inches white radish root"
    },
    {
      "name": "1 cup fenugreek leaves (- chopped)"
    },
    {
      "name": "1 cup chopped onions (or 2 medium sized onions)"
    },
    {
      "name": "1.5 cups chopped tomatoes (or 3 medium-sized tomatoes)"
    },
    {
      "name": "2 inches ginger (- chopped)"
    },
    {
      "name": "2 green chilies (- chopped)"
    },
    {
      "name": "7 to 8 garlic (- medium sized, chopped)"
    },
    {
      "name": "½ teaspoon red chili powder"
    },
    {
      "name": "2 to 3 pinches asafoetida (or ⅛ teaspoon asafoetida powder (hing))"
    },
    {
      "name": "2 to 3 cups water (or add as required)"
    },
    {
      "name": "2 tablespoon maize flour (or fine cornmeal)"
    },
    {
      "name": "salt (as required)"
    },
    {
      "name": "⅓ cup finely chopped onions (or 1 small to medium-sized onion)"
    },
    {
      "name": "1 to 2 tablespoons oil (or ghee)"
    },
    {
      "name": "2 cups cooked saag (or as required)"
    }
  ],
  "recipeInstructions": [
    {
      "name": "Making sarson ka saag",
      "itemListElement": [
        {
          "text": "Firstly clean and chop all the greens. Then wash or rinse the greens very well in running water.",
          "url": "https://www.vegrecipesofindia.com/sarson-ka-saag/#wprm-recipe-135022-step-0-0"
        },
        {
          "text": "In a 5 litre stovetop pressure cooker or pan add all the ingredients listed under \"for sarson ka saag\" except for maize flour.",
          "url": "https://www.vegrecipesofindia.com/sarson-ka-saag/#wprm-recipe-135022-step-0-1"
        },
        {
          "text": "Cover the pressure cook and cook for 6 to 7 minutes or more on medium-high heat.",
          "url": "https://www.vegrecipesofindia.com/sarson-ka-saag/#wprm-recipe-135022-step-0-2"
        },
        {
          "text": "If cooking in a pan, then cover and let the greens cook till tender and softened. Do check occasionally.",
          "url": "https://www.vegrecipesofindia.com/sarson-ka-saag/#wprm-recipe-135022-step-0-3"
        },
        {
          "text": "Pour the greens along with the stock and maize flour in a blender. Blend till smooth.",
          "url": "https://www.vegrecipesofindia.com/sarson-ka-saag/#wprm-recipe-135022-step-0-4"
        },
        {
          "text": "In another deep pan or in the same cooker, pour the pureed greens.",
          "url": "https://www.vegrecipesofindia.com/sarson-ka-saag/#wprm-recipe-135022-step-0-5"
        },
        {
          "text": "Simmer for a good 25 to 30 minutes on a low heat stirring at intervals.",
          "url": "https://www.vegrecipesofindia.com/sarson-ka-saag/#wprm-recipe-135022-step-0-6"
        }
      ]
    },
    {
      "name": "Tempering for sarson da saag",
      "itemListElement": [
        {
          "text": "In another small pan, heat oil. Use any neutral oil. You can also make the tempering with ghee if you prefer.",
          "url": "https://www.vegrecipesofindia.com/sarson-ka-saag/#wprm-recipe-135022-step-1-0"
        },
        {
          "text": "Add the chopped onions and saute them till light brown on medium-low heat.",
          "url": "https://www.vegrecipesofindia.com/sarson-ka-saag/#wprm-recipe-135022-step-1-1"
        },
        {
          "text": "Add the prepared saag. Stir and simmer for a couple of minutes.",
          "url": "https://www.vegrecipesofindia.com/sarson-ka-saag/#wprm-recipe-135022-step-1-2"
        },
        {
          "text": "Stir ocaasionally when the saag is simmering.",
          "url": "https://www.vegrecipesofindia.com/sarson-ka-saag/#wprm-recipe-135022-step-1-3"
        }
      ]
    },
    {
      "name": "Serving Suggestions",
      "itemListElement": [
        {
          "text": "Serve sarson ka saag hot with a side of some chopped onions, whole green chilies or mango pickle. Top the saag with a dollop of white butter and serve with Makki di Roti. Also serve a few jaggery cubes by the side.",
          "url": "https://www.vegrecipesofindia.com/sarson-ka-saag/#wprm-recipe-135022-step-2-0"
        },
        {
          "text": "For a vegan saag, omit adding white butter or use vegan butter.",
          "url": "https://www.vegrecipesofindia.com/sarson-ka-saag/#wprm-recipe-135022-step-2-1"
        }
      ]
    },
    {
      "name": "Storage",
      "itemListElement": [
        {
          "text": "Store the pureed and simmered saag in an airtight container for 4 to 5 days in the refrigerarot. You can also freeze it for a month.",
          "url": "https://www.vegrecipesofindia.com/sarson-ka-saag/#wprm-recipe-135022-step-3-0"
        },
        {
          "text": "When ready to serve, remove the quantity you need from the refrigerator and temper it with the required amout of oil and onions.",
          "url": "https://www.vegrecipesofindia.com/sarson-ka-saag/#wprm-recipe-135022-step-3-1"
        }
      ]
    }
  ],
