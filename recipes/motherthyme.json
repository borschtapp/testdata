  "recipeIngredient": [
    {
      "name": "1 3/4 cup milk"
    },
    {
      "name": "2 tablespoons brown sugar"
    },
    {
      "name": "1 tablespoon sugar"
    },
    {
      "name": "1/2 teaspoon vanilla extract"
    },
    {
      "name": "1/4 teaspoon salt"
    },
    {
      "name": "1 1/2 cups old-fashioned rolled oats"
    },
    {
      "name": "Topping"
    },
    {
      "name": "2 tablespoons butter (melted)"
    },
    {
      "name": "3 tablespoons packed light brown sugar"
    },
    {
      "name": "1 1/2 teaspoons cinnamon"
    },
    {
      "name": "Glaze"
    },
    {
      "name": "1 ounce cream cheese (softened)"
    },
    {
      "name": "1 tablespoon milk"
    },
    {
      "name": "1/8 teaspoon vanilla extract"
    },
    {
      "name": "5 tablespoons confectioners’ sugar"
    }
  ],
  "recipeInstructions": [
    {
      "text": "In a large saucepan add milk, sugars, vanilla and salt and bring to a boil over medium heat.",
      "url": "https://www.motherthyme.com/2014/01/cinnamon-roll-oatmeal.html#instruction-step-2"
    },
    {
      "text": "Stir in oats, return to a boil and continue to cook, stirring occasionally for 3-5 minutes until oatmeal begins to thicken.",
      "url": "https://www.motherthyme.com/2014/01/cinnamon-roll-oatmeal.html#instruction-step-3"
    },
    {
      "text": "Cover and remove from heat. Let sit for about 3 minutes.",
      "url": "https://www.motherthyme.com/2014/01/cinnamon-roll-oatmeal.html#instruction-step-4"
    },
    {
      "text": "In a small bowl mix butter, brown sugar and cinnamon until combined.",
      "url": "https://www.motherthyme.com/2014/01/cinnamon-roll-oatmeal.html#instruction-step-6"
    },
    {
      "text": "Microwave cream cheese in a small bowl for about 10 seconds until just melted.",
      "url": "https://www.motherthyme.com/2014/01/cinnamon-roll-oatmeal.html#instruction-step-8"
    },
    {
      "text": "Stir in confectioners’ sugar until combined.",
      "url": "https://www.motherthyme.com/2014/01/cinnamon-roll-oatmeal.html#instruction-step-9"
    },
    {
      "text": "Stir in milk and vanilla until creamy.",
      "url": "https://www.motherthyme.com/2014/01/cinnamon-roll-oatmeal.html#instruction-step-10"
    },
    {
      "name": "Note",
      "text": "Add in a little more confectioners’ sugar if glaze is too thin or a little more milk if glaze is too thick until desired consistency.",
      "url": "https://www.motherthyme.com/2014/01/cinnamon-roll-oatmeal.html#instruction-step-11"
    },
    {
      "text": "Place desired amount of oatmeal in serving bowl. Drizzle with some of the cinnamon sugar topping and then drizzle on top of that some of the cream cheese glaze.",
      "url": "https://www.motherthyme.com/2014/01/cinnamon-roll-oatmeal.html#instruction-step-13"
    },
    {
      "text": "Serve warm.",
      "url": "https://www.motherthyme.com/2014/01/cinnamon-roll-oatmeal.html#instruction-step-14"
    }
  ],
