  "recipeIngredient": [
    "1 cup tahini or creamy nut butter",
    "1/4 cup maple syrup",
    "1/2 cup coconut sugar",
    "2 pasture-raised eggs*",
    "1 teaspoon vanilla extract",
    "1/3 cup + 2 tablespoons cacao powder",
    "1 teaspoon baking powder",
    "1/2 cup dark chocolate chips"
  ],
  "recipeInstructions": [
    {
      "text": "Preheat oven to 350 degrees and line an 8×8 baking dish with parchment paper and grease well",
      "url": "https://rachlmansfield.com/healthy-flourless-brownies/#instruction-step-1"
    },
    {
      "text": "Cream together the tahini, maple syrup, coconut sugar, eggs and vanilla",
      "url": "https://rachlmansfield.com/healthy-flourless-brownies/#instruction-step-2"
    },
    {
      "text": "Mix in the cacao powder and baking powder until well combined (it will be thick!)",
      "url": "https://rachlmansfield.com/healthy-flourless-brownies/#instruction-step-3"
    },
    {
      "text": "Fold in dark chocolate gems then add batter to baking dish",
      "url": "https://rachlmansfield.com/healthy-flourless-brownies/#instruction-step-4"
    },
    {
      "text": "Bake in oven for 22-25 minutes (or until toothpick comes out clean when you poke the brownies)",
      "url": "https://rachlmansfield.com/healthy-flourless-brownies/#instruction-step-5"
    },
    {
      "text": "Allow the brownies to cool for a few minutes (this is key so they set!) then slice and enjoy!",
      "url": "https://rachlmansfield.com/healthy-flourless-brownies/#instruction-step-6"
    }
  ],
