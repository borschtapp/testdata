  "recipeYield": "4",
  "recipeIngredient": [
    {
      "name": "1/2 cup unsalted butter (4 ounces)"
    },
    {
      "name": "5 large garlic cloves, minced"
    },
    {
      "name": "1 fresh Scotch bonnet chile, stemmed, unseeded, and minced (about 1 tablespoon)"
    },
    {
      "name": "1 1/2 teaspoons minced peeled fresh ginger"
    },
    {
      "name": "1/2 cup fresh lime juice"
    },
    {
      "name": "1/2 cup distilled white vinegar"
    },
    {
      "name": "1 thyme sprig"
    },
    {
      "name": "3 pounds unpeeled head-on raw large shrimp, deveined"
    },
    {
      "name": "1 teaspoon kosher salt"
    }
  ],
  "recipeInstructions": [
    {
      "text": "Melt butter in a large pot over medium. Add garlic, chile, and ginger; cook, stirring often, until aromatic and tender, about 5 minutes. Add lime juice, vinegar, and thyme; bring to a simmer over medium. Increase heat to medium-high; add shrimp, and cook, stirring often, until shrimp are opaque and cooked through, about 5 minutes. Remove from heat. Sprinkle with salt, and serve immediately."
    }
  ],
