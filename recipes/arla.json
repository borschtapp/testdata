  "recipeInstructions": [
    {
      "name": "Första instruktionen",
      "itemListElement": [
        {
          "text": "Skala och finhacka löken till dressingen. Finhacka även paprikan. Blanda med övriga ingredienser och ställ dressingen åt sidan.",
          "url": "https://www.arla.se/recept/reuben-sandwich/#step1-1"
        }
      ]
    },
    {
      "name": "Sista instruktionen",
      "itemListElement": [
        {
          "text": "Skär köttet i tunna skivor. Låt surkålen rinna av ordentligt och blanda med osten.",
          "url": "https://www.arla.se/recept/reuben-sandwich/#step2-1"
        },
        {
          "text": "Bred smör på båda sidor av bröden. Lägg surkål och ost på hälften av bröden. Lägg på köttet. Klicka dressingen över köttet och lägg på resterande bröd.",
          "url": "https://www.arla.se/recept/reuben-sandwich/#step2-2"
        },
        {
          "text": "Stek på båda sidor i enstek- eller het grillpanna.",
          "url": "https://www.arla.se/recept/reuben-sandwich/#step2-3"
        },
        {
          "text": "Dela grillspett på mitten och trä genom mackorna. Fäst saltgurkorna på grillspetten.",
          "url": "https://www.arla.se/recept/reuben-sandwich/#step2-4"
        }
      ]
    }
  ],
