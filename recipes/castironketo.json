  "recipeIngredient": [
    "1 ½ pounds cooked shredded chicken breast",
    "4 green onions (chopped)",
    "1 teaspoon garlic salt",
    "½ teaspoon onion powder",
    "½ teaspoon paprika",
    "8 ounces cream cheese (softened)",
    "½ cup heavy cream",
    "¼ cup chicken broth",
    "5 jalapeno peppers (halved (ribs removed if you like less spice))",
    "1 cup shredded sharp cheddar cheese",
    "6 slices bacon (cooked and crumbled)"
  ],
  "recipeInstructions": [
    {
      "text": "Preheat the oven to 425° F.",
      "url": "https://www.castironketo.net/blog/keto-jalapeno-popper-casserole-with-chicken/#wprm-recipe-5984-step-0-0"
    },
    {
      "text": "Place the chicken in the bottom of a 10” or larger cast iron skillet. Top with green onions.",
      "url": "https://www.castironketo.net/blog/keto-jalapeno-popper-casserole-with-chicken/#wprm-recipe-5984-step-0-1"
    },
    {
      "text": "Combine the garlic salt, onion powder, paprika, cream cheese, heavy cream, and chicken bone broth in a small bowl. Mix until combined.",
      "url": "https://www.castironketo.net/blog/keto-jalapeno-popper-casserole-with-chicken/#wprm-recipe-5984-step-0-2"
    },
    {
      "text": "Pour the cream cheese mixture over the chicken then top with the slices of jalapeno. Sprinkle the cheddar cheese over the top then top with the crumbled bacon.",
      "url": "https://www.castironketo.net/blog/keto-jalapeno-popper-casserole-with-chicken/#wprm-recipe-5984-step-0-3"
    },
    {
      "text": "Transfer the skillet to the oven and bake for 15 minutes until the cheese is bubbly. Serve immediately.",
      "url": "https://www.castironketo.net/blog/keto-jalapeno-popper-casserole-with-chicken/#wprm-recipe-5984-step-0-4"
    }
  ],
