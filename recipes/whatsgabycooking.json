  "recipeYield": 6,
  "recipeIngredient": [
    "1 ½ cups uncooked multi-colored quinoa",
    "2 cups shredded colby jack cheese (divided)",
    "1 cup shredded mozzarella cheese (divided)",
    "1 cup canned black beans (rinsed and drained)",
    "1 cup frozen charred corn (trader joes)",
    "1 4.5-ounce can chopped green chiles",
    "1 ½ cup Gaby's chipotle or tomatillo salsa",
    "Kosher salt and pepper to taste",
    "Finely chopped scallions and cilantro as garnish"
  ],
  "recipeInstructions": [
    {
      "text": "Preheat the oven to 375 degrees F.",
      "url": "https://whatsgabycooking.com/vegetarian-quinoa-bake/#wprm-recipe-32292-step-0-0"
    },
    {
      "text": "Cook the quinoa according to the package directions. Once cooked, remove from heat and transfer the cooked quinoa into a large bowl.",
      "url": "https://whatsgabycooking.com/vegetarian-quinoa-bake/#wprm-recipe-32292-step-0-1"
    },
    {
      "text": "Fold in 1 1/2 cups of the shredded colby jack cheese, ½ cup of the shredded mozzarella, black beans, corn, green chiles and salsa. Season the entire mixture with salt and pepper and stir to combine.",
      "url": "https://whatsgabycooking.com/vegetarian-quinoa-bake/#wprm-recipe-32292-step-0-2"
    },
    {
      "text": "Lightly spray a medium sized skillet with non-stick spray, and transfer the mixture into the skillet. Top with the remaining shredded cheeses and bake for about 20-25 minutes until the top layer of cheese is bubbly and melted.",
      "url": "https://whatsgabycooking.com/vegetarian-quinoa-bake/#wprm-recipe-32292-step-0-3"
    },
    {
      "text": "Remove the baking dish from the oven and garnish with green onions and cilantro and serve.",
      "url": "https://whatsgabycooking.com/vegetarian-quinoa-bake/#wprm-recipe-32292-step-0-4"
    }
  ],
