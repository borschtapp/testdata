  "recipeInstructions": [
    {
      "text": "Cook pasta according to package directions then drain under cold water to stop cooking.",
      "url": "https://picky-palate.com/cheesy-grown-up-spaghettios/#wprm-recipe-52946-step-0-0"
    },
    {
      "text": "Melt butter into a large dutch oven or pot over medium heat. Add tomato sauce, stirring to combine.",
      "url": "https://picky-palate.com/cheesy-grown-up-spaghettios/#wprm-recipe-52946-step-0-1"
    },
    {
      "text": "Add your cooked pasta to the sauce along with the shredded chicken, Ranch seasoning and black pepper. Stir to combine, reduce heat to medium low.",
      "url": "https://picky-palate.com/cheesy-grown-up-spaghettios/#wprm-recipe-52946-step-0-2"
    },
    {
      "text": "Top with shredded cheese and close lid to melt cheese for 3-5 minutes. Once cheese is melted, serve.",
      "url": "https://picky-palate.com/cheesy-grown-up-spaghettios/#wprm-recipe-52946-step-0-3"
    }
