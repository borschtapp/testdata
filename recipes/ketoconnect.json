  "recipeIngredient": [
    {
      "name": "1.5 lbs Precooked Chicken Breast Shredded (Can be baked or boiled)"
    },
    {
      "name": "1 tbsp Olive Oil"
    },
    {
      "name": "3 cloves Minced Garlic"
    },
    {
      "name": "1/2 c Diced Onion"
    },
    {
      "name": "18 oz Block of Cream Cheese"
    },
    {
      "name": "4 cups Chicken Broth"
    },
    {
      "name": "7 oz Can Green Chilis"
    },
    {
      "name": "1/4 c Heavy Cream"
    },
    {
      "name": "2 tbsp Cilantro"
    },
    {
      "name": "1+1/2 tsp Cumin"
    },
    {
      "name": "1/4 tsp Cayenne"
    },
    {
      "name": "3/4 tsp Oregano"
    },
    {
      "name": "3/4 tsp Paprika"
    },
    {
      "name": "1/2 tsp Pepper"
    },
    {
      "name": "1 tsp Salt"
    }
  ],
  "recipeInstructions": [
    {
      "text": "Add oil to a pot and sauté the garlic and onions until translucent over medium heat.",
      "url": "https://www.ketoconnect.net/keto-white-chicken-chili/#wprm-recipe-47462-step-0-0"
    },
    {
      "text": "Pour in the spices and and toast them for 2 minutes with the onions and garlic.",
      "url": "https://www.ketoconnect.net/keto-white-chicken-chili/#wprm-recipe-47462-step-0-1"
    },
    {
      "text": "Add in the broth and bring to a simmer. Simmer for 15 minutes.",
      "url": "https://www.ketoconnect.net/keto-white-chicken-chili/#wprm-recipe-47462-step-0-2"
    },
    {
      "text": "Once simmered add in the chicken, chilis, cream cheese, heavy cream, and cilantro.",
      "url": "https://www.ketoconnect.net/keto-white-chicken-chili/#wprm-recipe-47462-step-0-3"
    },
    {
      "text": "Serve warm with Keto tortilla chips, avocado, limes, and extra cilantro.",
      "url": "https://www.ketoconnect.net/keto-white-chicken-chili/#wprm-recipe-47462-step-0-4"
    }
