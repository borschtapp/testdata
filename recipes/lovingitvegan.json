  "recipeIngredient": [
    {
      "name": "1 1/4 cups Soy Milk ((300ml) or Almond Milk)"
    },
    {
      "name": "2 Frozen Bananas ((200g) previously peeled, broken into quarters and frozen for at least 12 hours)"
    },
    {
      "name": "1/2 cup Raw Cashews ((75g))"
    },
    {
      "name": "2 cups Kale ((56g) Torn up, packed)"
    },
    {
      "name": "4 Medjool Dates (Pitted)"
    },
    {
      "name": "1 tsp Minced Ginger"
    },
    {
      "name": "1/8 tsp Cinnamon"
    },
    {
      "name": "1 Tbsp Lime Juice (freshly squeezed)"
    },
    {
      "name": "1 cup Ice Cubes"
    }
  ],
  "recipeInstructions": [
    {
      "text": "Add the soy milk to your blender jug and then the frozen bananas, cashews, kale, dates, minced ginger, cinnamon and fresh lime juice. Top with ice cubes.",
      "url": "https://lovingitvegan.com/kale-smoothie/#wprm-recipe-9766-step-0-0"
    },
    {
      "text": "Blend until very smooth.",
      "url": "https://lovingitvegan.com/kale-smoothie/#wprm-recipe-9766-step-0-1"
    },
    {
      "text": "Pour out into glasses and serve immediately.",
      "url": "https://lovingitvegan.com/kale-smoothie/#wprm-recipe-9766-step-0-2"
    }
  ],
