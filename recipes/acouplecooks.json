  "recipeIngredient": [
    {
      "name": "1 pound large shrimp, deveined (peeled or unpeeled)"
    },
    {
      "name": "3 garlic cloves"
    },
    {
      "name": "1/2 teaspoon kosher salt"
    },
    {
      "name": "3 tablespoons butter"
    },
    {
      "name": "2 lemon wedges"
    },
    {
      "name": "Fresh cilantro or parsley, for garnish"
    }
  ],
  "recipeInstructions": [
    {
      "text": "If frozen, thaw the shrimp (see the notes above).",
      "url": "https://www.acouplecooks.com/garlic-butter-shrimp/#instruction-step-1"
    },
    {
      "text": "Mince the garlic.",
      "url": "https://www.acouplecooks.com/garlic-butter-shrimp/#instruction-step-2"
    },
    {
      "text": "Pat the shrimp dry. In a medium bowl, mix the shrimp with the garlic and salt.",
      "url": "https://www.acouplecooks.com/garlic-butter-shrimp/#instruction-step-3"
    },
    {
      "text": "In a large skillet, heat the butter on medium high heat. Cook the shrimp for 1 to 2 minutes per side until opaque and cooked through, turning them with tongs.",
      "url": "https://www.acouplecooks.com/garlic-butter-shrimp/#instruction-step-4"
    },
    {
      "text": "Spritz with juice of the lemon wedges and serve immediately.",
      "url": "https://www.acouplecooks.com/garlic-butter-shrimp/#instruction-step-5"
    }
  ],
