  "recipeInstructions": [
    {
      "text": "All set?",
      "image": "https://images.kptncook.com/59b8e8d5950000fc1649a085.jpg?kptnkey=6q7QNKy-oIgk-IMuWisJ-jfN7s6"
    },
    {
      "text": "Preheat oven to 360°F (conventional, recommended) or 325°F (fan).",
      "image": "https://images.kptncook.com/617a6f76380000320017b5f1.jpg?kptnkey=6q7QNKy-oIgk-IMuWisJ-jfN7s6"
    },
    {
      "text": "Mix curd, eggs, chili flakes, herbes de Provence, salt, and pepper to a bowl and mix.",
      "image": "https://images.kptncook.com/59b8e8f69500000e1749a087.jpg?kptnkey=6q7QNKy-oIgk-IMuWisJ-jfN7s6"
    },
    {
      "text": "Place the mass on a lined baking sheet, spread thinly (make sure the layer is very thin) and bake for .",
      "image": "https://images.kptncook.com/59b8e9019500001f1749a088.jpg?kptnkey=6q7QNKy-oIgk-IMuWisJ-jfN7s6"
    },
    {
      "text": "Wash and slice cherry tomatoes.",
      "image": "https://images.kptncook.com/61aa1f254a0000de07d9d05f.jpg?kptnkey=6q7QNKy-oIgk-IMuWisJ-jfN7s6"
    },
    {
      "text": "Wash and dry arugula.",
      "image": "https://images.kptncook.com/60768f7f6c00008d00f17e45.jpg?kptnkey=6q7QNKy-oIgk-IMuWisJ-jfN7s6"
    },
    {
      "text": "Remove the base from the oven and spread with cream cheese. Top with tomatoes and Serrano ham, and bake for another .",
      "image": "https://images.kptncook.com/59b8e922950000f51649a08b.jpg?kptnkey=6q7QNKy-oIgk-IMuWisJ-jfN7s6"
    },
    {
      "text": "Remove the tarte flambée from the oven, top with arugula, and enjoy.",
      "image": "https://images.kptncook.com/59b8e92b950000261749a08c.jpg?kptnkey=6q7QNKy-oIgk-IMuWisJ-jfN7s6"
    }
