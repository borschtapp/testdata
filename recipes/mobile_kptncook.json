    },
    {
      "text": "Wash and slice cherry tomatoes.",
      "image": "https://images.kptncook.com/61aa1f254a0000de07d9d05f.jpg?kptnkey=6q7QNKy-oIgk-IMuWisJ-jfN7s6"
    },
    {
      "text": "Wash and dry arugula.",
