  "recipeIngredient": [
    {
      "name": "1 pound ground lamb (or 1/2 pound each of ground lamb and ground beef)"
    },
    {
      "name": "1 egg"
    },
    {
      "name": "4 cloves garlic (peeled and finely minced)"
    },
    {
      "name": "1 teaspoon ground cumin"
    },
    {
      "name": "1 teaspoon ground coriander"
    },
    {
      "name": "1 teaspoon smoked paprika"
    },
    {
      "name": "1 teaspoon dried oregano"
    },
    {
      "name": "1/2 teaspoon salt"
    },
    {
      "name": "1/4 teaspoon ground black pepper"
    },
    {
      "name": "1 tablespoon oil (for the skillet, plus extra for the pan)"
    },
    {
      "name": "4 rounds of pita (or naan or flatbread)"
    },
    {
      "name": "1 cup assorted lettuce"
    },
    {
      "name": "1 large tomato (sliced)"
    },
    {
      "name": "1/2 seedless English cucumber (sliced)"
    },
    {
      "name": "1/4 large red onion (peeled and sliced)"
    },
    {
      "name": "Tzatziki sauce or tahini sauce"
    }
  ],
  "recipeInstructions": [
    {
      "text": "Gather the ingredients.",
      "image": "https://www.thespruceeats.com/thmb/8ObXWnNje4e3TiYGaXzoSq2DYDw=/1500x0/filters:no_upscale():max_bytes(150000):strip_icc()/doner-kebab-recipe-4171703-step-01-3b8619e293984e89a7d980d4955e8f3b.jpg"
    },
    {
      "text": "Pre heat the oven to 350 F. In a large bowl, combine the ground lamb, egg, garlic, ground cumin, ground coriander, smoked paprika, dried oregano, salt, and black pepper.",
      "image": "https://www.thespruceeats.com/thmb/Uq2r9y0ONRQIeFSostT9s0iwqUI=/1500x0/filters:no_upscale():max_bytes(150000):strip_icc()/doner-kebab-recipe-4171703-step-02-ef9f1276aa4a45fcac9addc44568aa11.jpg"
    },
    {
      "text": "Place the mixture into an oiled 9 x 5-inch loaf pan and cook in the oven for approximately 30 minutes or until the top is a light golden brown.",
      "image": "https://www.thespruceeats.com/thmb/_RahSP5oGwt8aptuwxtcDamBTpw=/1500x0/filters:no_upscale():max_bytes(150000):strip_icc()/doner-kebab-recipe-4171703-step-03-6a0eb603814142ce8fa1feb8e00f7583.jpg"
    },
    {
      "text": "You can slice the loaf immediately if you like but, for best results, cool completely, wrap in aluminum foil, and refrigerate until firm.",
      "image": "https://www.thespruceeats.com/thmb/RvtdQZEGdxvlUH1zgq0REPsIwTE=/1500x0/filters:no_upscale():max_bytes(150000):strip_icc()/doner-kebab-recipe-4171703-step-04-98ada6b090fd45b8b56f6163e3c75ab7.jpg"
    },
    {
      "text": "To reheat, add a little olive oil to a large skillet, slice the loaf very thinly and crisp up the slices in the hot pan for a few minutes.",
      "image": "https://www.thespruceeats.com/thmb/RRte9gP99ZakmmqfKH3N4Oj3Npc=/1500x0/filters:no_upscale():max_bytes(150000):strip_icc()/doner-kebab-recipe-4171703-step-05-84e395c48e0f492aae6ef520b9fd2b9a.jpg"
    },
    {
      "text": "Assemble the sandwiches with pita, warmed and toasted through. Spread on some tzatziki or tahini sauce, add lettuce, tomato, cucumber, onion, and top with more sauce.",
      "image": "https://www.thespruceeats.com/thmb/ZiUUlc2vjWJCuZ6Uugf4ftcvNf0=/1500x0/filters:no_upscale():max_bytes(150000):strip_icc()/doner-kebab-recipe-4171703-step-06-c0312452b24f4c5bac2f6b391f64a7d6.jpg"
    }
  ],
